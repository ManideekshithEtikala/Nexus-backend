# ==============================================================================
# NEXUS CORE FRAMEWORK - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all values with your actual credentials
# 3. NEVER commit .env file to git (it's in .gitignore)
# 4. Keep this .env.example file committed for reference
#
# ==============================================================================

# ==============================================================================
# LLM & API CONFIGURATION
# ==============================================================================
# Groq API Key
API_KEY="gsk_your_groq_api_key_here"

# Database Configuration - PostgreSQL
DATABASE_HOST=localhost
DATABASE_NAME=chat_bot
DATABASE_USER_NAME=postgres
DATABASE_PORT=5432
DATABASE_PASS=your_password_here
DATABASE_SSL=require # use 'require' for Aiven, 'disable' for local if needed

# Vector Embeddings Configuration
EMBEDDING_PROVIDER="google"
EMBEDDING_MODEL="text-embedding-004"
GEMINI_API_KEY="AIzaSy_your_gemini_api_key_here"

# Long-term Vector Memory - PINECONE
PINECONE_API_KEY="pcsk_your_pinecone_api_key_here"
PINECONE_INDEX_NAME="nexus-memory"

# ==============================================================================
# OPTIONAL: Advanced Database Configuration
# ==============================================================================
# Uncomment and modify if needed for special database setups
# DATABASE_POOL_SIZE=10              # Connection pool size
# DATABASE_MAX_OVERFLOW=20           # Max overflow connections
# DATABASE_POOL_TIMEOUT=30           # Pool timeout in seconds
# DATABASE_ECHO=false                # Log all SQL queries (debug mode)
