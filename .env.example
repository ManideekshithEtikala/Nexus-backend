# ==============================================================================
# Nexus Core Framework Backend Environment Configuration
# Copy this file to '.env' and fill in your keys.
# ==============================================================================

# Groq API Key (Used for LLM inference with Qwen-32B)
API_KEY="gsk_your_groq_api_key_here"

# Google Gemini API Key (Used for free high-performance vector embeddings)
# Standard rate limits apply (1500 RPM), which is completely free for testing.
GEMINI_API_KEY="AIzaSy_your_gemini_api_key_here"

# Pinecone Credentials (Used for long-term vector database memory storage)
# You can get a free serverless index key from the Pinecone Console.
PINECONE_API_KEY="pcsk_your_pinecone_api_key_here"
PINECONE_INDEX_NAME="nexus-memory-cloud"

# Embedding Configurations
EMBEDDING_PROVIDER="google"  # Options: "google", "openai", "huggingface"
EMBEDDING_MODEL="text-embedding-004" # Standard Google free-tier embedding model (768 dimensions)

# Database Configurations
# Default connection points to a local PostgreSQL instance named 'chat_bot'
DATABASE_URL="postgresql+asyncpg://postgres:Manideekshith%4011@localhost:5432/chat_bot"
