# ==============================================================================
# NEXUS CORE FRAMEWORK - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all values with your actual credentials
# 3. NEVER commit .env file to git (it's in .gitignore)
# 4. Keep this .env.example file committed for reference
#
# ==============================================================================

# ==============================================================================
# LLM & API CONFIGURATION
# ==============================================================================
# Get your free Groq API key from: https://console.groq.com
API_KEY="gsk_your_groq_api_key_here"

# ==============================================================================
# DATABASE CONFIGURATION - PostgreSQL
# ==============================================================================
#
# LOCAL DEVELOPMENT (your machine):
# ============================================
# PostgreSQL Connection String Format:
#   postgresql+asyncpg://username:password@host:port/database
#
# Example for local PostgreSQL:
#   DATABASE_URL="postgresql+asyncpg://postgres:MyPassword123@localhost:5432/chat_bot"
#
# Example for Aiven PostgreSQL:
#   DATABASE_URL="postgresql+asyncpg://avnadmin:password@host:port/defaultdb?sslmode=require"
#
# If your password contains special characters, URL-encode them:
#   @ becomes %40
#   : becomes %3A
#   # becomes %23
#
# Example: password "Pass@word:123" becomes "Pass%40word%3A123"
#
# PRODUCTION DEPLOYMENT ON RENDER:
# ============================================
# DO NOT set DATABASE_URL in local .env for Render deployment
# Instead:
#   1. Create PostgreSQL database on Render (free tier available)
#   2. Render automatically provides DATABASE_URL environment variable
#   3. Set it in Render dashboard: Dashboard → Web Service → Environment
#   4. The backend code automatically converts "postgresql://" to "postgresql+asyncpg://"
#   5. Deploy your backend - connection works automatically
#
DATABASE_URL="postgresql+asyncpg://postgres:your_password_here@localhost:5432/chat_bot"

# ==============================================================================
# VECTOR EMBEDDINGS CONFIGURATION
# ==============================================================================
# Provider: google, openai, or huggingface
# Get free Google Gemini API from: https://aistudio.google.com/apikey
EMBEDDING_PROVIDER="google"
EMBEDDING_MODEL="text-embedding-004"
GEMINI_API_KEY="AIzaSy_your_gemini_api_key_here"

# ==============================================================================
# LONG-TERM VECTOR MEMORY - PINECONE
# ==============================================================================
# Get free Pinecone account from: https://www.pinecone.io
# Create serverless index for free tier
PINECONE_API_KEY="pcsk_your_pinecone_api_key_here"
PINECONE_INDEX_NAME="nexus-memory"

# ==============================================================================
# OPTIONAL: Advanced Database Configuration
# ==============================================================================
# Uncomment and modify if needed for special database setups
# DATABASE_POOL_SIZE=10              # Connection pool size
# DATABASE_MAX_OVERFLOW=20           # Max overflow connections
# DATABASE_POOL_TIMEOUT=30           # Pool timeout in seconds
# DATABASE_ECHO=false                # Log all SQL queries (debug mode)
